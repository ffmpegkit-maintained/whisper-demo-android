<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:text="FFmpegKit 8.1 — Whisper Demo"
            android:textSize="22sp"
            android:textStyle="bold"
            android:layout_marginBottom="20dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <!-- ══ MODEL ═══════════════════════════════════════════════ -->

        <TextView
            android:text="WHISPER MODEL"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/tvModelStatus"
            android:text="No model — download one below"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="8dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <Button
                android:id="@+id/btnDownloadTiny"
                android:text="tiny  75 MB"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="wrap_content" />

            <Button
                android:id="@+id/btnDownloadBase"
                android:text="base  142 MB"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="wrap_content" />

        </LinearLayout>

        <!-- ══ VIDEO PATH ════════════════════════════════════════════ -->

        <TextView
            android:text="VIDEO"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:letterSpacing="0.1"
            android:layout_marginTop="20dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <LinearLayout
            android:orientation="horizontal"
            android:layout_marginTop="4dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <EditText
                android:id="@+id/etVideoPath"
                android:text="/sdcard/Movies/Vol_election.mp4"
                android:inputType="textUri"
                android:singleLine="true"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="wrap_content" />

            <Button
                android:id="@+id/btnBrowse"
                android:text="..."
                android:layout_marginStart="4dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

        </LinearLayout>

        <!-- ══ ACTIONS ════════════════════════════════════════════════ -->

        <LinearLayout
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <Button
                android:id="@+id/btnAnalyze"
                android:text="Analyser"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="wrap_content" />

            <Button
                android:id="@+id/btnExport"
                android:text="Exporter"
                android:enabled="false"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="wrap_content" />

        </LinearLayout>

        <TextView
            android:id="@+id/tvProgress"
            android:layout_marginTop="8dp"
            android:minLines="2"
            android:textStyle="italic"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <!-- ══ VIDEO PLAYER (hidden until analysis completes) ════════ -->

        <FrameLayout
            android:id="@+id/playerCard"
            android:layout_marginTop="12dp"
            android:visibility="gone"
            android:background="#000000"
            android:layout_width="match_parent"
            android:layout_height="220dp">

            <VideoView
                android:id="@+id/videoView"
                android:layout_gravity="center"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <!-- Subtitle overlay at bottom of video -->
            <TextView
                android:id="@+id/tvSubtitle"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="6dp"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="3dp"
                android:paddingBottom="3dp"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:gravity="center"
                android:background="#CC000000"
                android:visibility="invisible"
                android:maxWidth="320dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

        </FrameLayout>

        <!-- ══ LANGUAGE SELECTOR (hidden until analysis completes) ═══ -->

        <LinearLayout
            android:id="@+id/langCard"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="4dp"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <Button
                android:id="@+id/btnFr"
                android:text="FR"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="wrap_content" />

            <Button
                android:id="@+id/btnEn"
                android:text="EN"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="wrap_content" />

            <Button
                android:id="@+id/btnEs"
                android:text="ES"
                android:layout_marginStart="4dp"
                android:layout_weight="1"
                android:layout_width="0dp"
                android:layout_height="wrap_content" />

        </LinearLayout>

        <!-- ══ STATS (hidden until analysis completes) ═══════════════ -->

        <LinearLayout
            android:id="@+id/statsCard"
            android:orientation="vertical"
            android:padding="12dp"
            android:layout_marginTop="12dp"
            android:background="#12000000"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:text="Performance"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/tvStatTime"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/tvStatModel"
                android:layout_marginTop="2dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/tvStatFfmpeg"
                android:layout_marginTop="2dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/tvStatInfo"
                android:layout_marginTop="2dp"
                android:textSize="11sp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

            <TextView
                android:text="100% on-device — no internet required for transcription"
                android:layout_marginTop="6dp"
                android:textStyle="italic"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>
